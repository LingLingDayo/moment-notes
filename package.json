{
  "name": "utools-sticky-notes",
  "version": "1.1.0",
  "private": true,
  "description": "拾光便签：一款基于 Vue 3 + TypeScript + Vite 构建的高颜值、高生产力的 uTools 便签插件。",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --fix",
    "lint:nocache": "eslint src --fix --no-cache",
    "deploy": "node scripts/deploy.js",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.25.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "utools-api-types": "^7.5.1",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
